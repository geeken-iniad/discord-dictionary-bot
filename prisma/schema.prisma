// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // ※SQLiteの場合は "sqlite" のままにしてください
  url      = env("DATABASE_URL")
}



// 1. 「意味」や「画像」を持つ本体
model Word {
  id         Int      @id @default(autoincrement())
  meaning    String
  authorName String?
  imageUrl   String?
  link       String?  // 👈 これを追加！ (?をつけるのを忘れずに)
  createdAt  DateTime @default(now())
  
  titles     Title[]
}

// 2. 「見出し語」専用のテーブル
model Title {
  id     Int    @id @default(autoincrement())
  text   String @unique // 単語そのもの (重複禁止)
  
  // 👇 Wordテーブルと紐付ける設定
  word   Word   @relation(fields: [wordId], references: [id], onDelete: Cascade)
  wordId Int
}