// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Word {
  id         Int      @id @default(autoincrement())
  guildId    String   @default("global") // 👈 【追加】サーバーIDを保存する名札！（既存データエラー防止のため初期値付き）
  meaning    String
  contextLabel String?
  contextKeywords String?
  authorName String?
  imageUrl   String?
  link       String?
  tag        String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
  
  titles     Title[]
}

model Title {
  id     Int    @id @default(autoincrement())
  text   String // 👈 【変更】@unique を削除しました！（別々のサーバーで同じ単語を登録できるようにするため）
  word   Word   @relation(fields: [wordId], references: [id], onDelete: Cascade)
  wordId Int
}

model EscapedThread {
  id        Int      @id @default(autoincrement())
  guildId   String
  threadId  String   @unique
  createdAt DateTime @default(now())
}

model WikiWord {
  id        Int      @id @default(autoincrement())
  term      String   @unique
  meaning   String
  link      String
  processed Boolean  @default(false) // 👈 説明文クリーニング処理完了フラグ
  updatedAt DateTime @updatedAt
}

model CalendarEvent {
  id         Int      @id @default(autoincrement())
  guildId    String   @default("global")
  eventName  String
  eventAt    DateTime
  location   String?
  eventDetails String?
  eventUrl   String?
  authorName String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
}