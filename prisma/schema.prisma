// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ▼▼▼ ここを追加 ▼▼▼
// "Word" という名前のテーブルを作ります
model Word {
  id      Int    @id @default(autoincrement()) // 通し番号
  term    String @unique                       // 単語（重複禁止）
  meaning String                               // 意味
  authorName String?
  imageUrl   String?
}