// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ▼▼▼ ここを追加 ▼▼▼
// "Word" という名前のテーブルを作ります
model Word {
  id         Int      @id @default(autoincrement())
  meaning    String
  authorName String?
  imageUrl   String?
  createdAt  DateTime @default(now())
  
  // 👇 Wordは複数の Title を持つ、という設定
  titles     Title[]
}
model Title {
  id     Int    @id @default(autoincrement())
  text   String @unique // 単語そのもの (重複禁止)
  
  // 👇 Wordテーブルと紐付ける設定
  word   Word   @relation(fields: [wordId], references: [id], onDelete: Cascade)
  wordId Int
}


// 将来的には各々の単語をリンクさせる => /で区切っていく
