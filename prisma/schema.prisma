// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Word {
  id         Int      @id @default(autoincrement())
  meaning    String
  authorName String?
  imageUrl   String?
  link       String?
  tag        String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt  // 👈 これを追加してください！
  
  titles     Title[]
}

model Title {
  id     Int    @id @default(autoincrement())
  text   String @unique
  word   Word   @relation(fields: [wordId], references: [id], onDelete: Cascade)
  wordId Int
}