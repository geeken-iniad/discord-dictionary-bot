{
  "name": "discord-dictionary-bot",
  "version": "1.0.0",
  "description": "discordの会話を豊かなものにしよう",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon src/index.ts",
    "register": "ts-node src/deploy-commands.ts",
    "build": "tsc",
    "start": "npx prisma db push && node dist/deploy-commands.js && node dist/index.js",
    "fetch-wiki": "ts-node src/scripts/fetchWiki.ts",
    "postinstall": "prisma generate"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Reossann/discord-dictionary-bot.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Reossann/discord-dictionary-bot/issues"
  },
  "homepage": "https://github.com/Reossann/discord-dictionary-bot#readme",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "discord.js": "^14.25.1",
    "dotenv": "^17.2.3",
    "fast-levenshtein": "^3.0.0"
  },
  "devDependencies": {
    "@types/fast-levenshtein": "^0.0.4",
    "@types/node": "^25.0.3",
    "nodemon": "^3.1.11",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
